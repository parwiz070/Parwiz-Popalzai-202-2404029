<section class="mb-12">
  <div class="glass-card premium-shadow rounded-[32px] p-10">

    <p class="text-teal-600 font-black uppercase tracking-[0.25em] text-sm">
      Clinic Control Center
    </p>

    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-8 mt-3">

      <div>
        <h1 class="text-5xl md:text-6xl font-black text-gray-900">
          Appointment Dashboard
        </h1>

        <p class="text-gray-500 mt-4 text-lg max-w-2xl">
          Manage patients, doctors, departments, appointment schedules and clinic workflow.
        </p>
      </div>

      <a href="/appointments/new" class="btn-luxury">
        + Add Appointment
      </a>

    </div>

  </div>
</section>

<section class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">

  <div class="glass-card premium-shadow rounded-[28px] p-6">
    <p class="text-gray-500 font-bold">Total</p>
    <h2 class="text-4xl font-black text-gray-900 mt-2">
      <%= stats.totalAppointments %>
    </h2>
  </div>

  <div class="glass-card premium-shadow rounded-[28px] p-6">
    <p class="text-gray-500 font-bold">Pending</p>
    <h2 class="text-4xl font-black text-yellow-500 mt-2">
      <%= stats.pendingAppointments %>
    </h2>
  </div>

  <div class="glass-card premium-shadow rounded-[28px] p-6">
    <p class="text-gray-500 font-bold">Confirmed</p>
    <h2 class="text-4xl font-black text-blue-500 mt-2">
      <%= stats.confirmedAppointments %>
    </h2>
  </div>

  <div class="glass-card premium-shadow rounded-[28px] p-6">
    <p class="text-gray-500 font-bold">Completed</p>
    <h2 class="text-4xl font-black text-green-500 mt-2">
      <%= stats.completedAppointments %>
    </h2>
  </div>

</section>

<section class="glass-card premium-shadow rounded-[32px] p-8 mb-10">

  <form method="GET" action="/dashboard" class="grid grid-cols-1 md:grid-cols-4 gap-4">

    <input
      type="text"
      name="search"
      value="<%= search %>"
      placeholder="Search patient or doctor..."
      class="input-luxury"
    />

    <select name="status" class="input-luxury">
      <option value="All">All Statuses</option>
      <option value="Pending" <%= selectedStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
      <option value="Confirmed" <%= selectedStatus === 'Confirmed' ? 'selected' : '' %>>Confirmed</option>
      <option value="Completed" <%= selectedStatus === 'Completed' ? 'selected' : '' %>>Completed</option>
      <option value="Cancelled" <%= selectedStatus === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
    </select>

    <select name="department" class="input-luxury">
      <option value="All">All Departments</option>

      <% departments.forEach(dep => { %>
        <option value="<%= dep %>" <%= selectedDepartment === dep ? 'selected' : '' %>>
          <%= dep %>
        </option>
      <% }) %>
    </select>

    <button class="btn-luxury">
      Search
    </button>

  </form>

</section>

<% if(appointments.length === 0) { %>

  <div class="glass-card premium-shadow rounded-[32px] p-16 text-center">
    <h2 class="text-4xl font-black text-gray-800">
      No Appointments Found
    </h2>

    <p class="text-gray-500 mt-4">
      Start by adding your first clinic appointment.
    </p>

    <a href="/appointments/new" class="inline-block mt-8 btn-luxury">
      Add First Appointment
    </a>
  </div>

<% } else { %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

    <% appointments.forEach(appointment => { %>

      <div class="glass-card premium-shadow rounded-[32px] p-7 hover:-translate-y-2 transition duration-300">

        <div class="flex justify-between items-start gap-4">

          <div>
            <h2 class="text-2xl font-black text-gray-900">
              <%= appointment.patientName %>
            </h2>

            <p class="text-gray-500 mt-1">
              Doctor: <%= appointment.doctorName %>
            </p>
          </div>

          <span class="px-4 py-2 rounded-full text-sm font-black bg-teal-100 text-teal-700">
            <%= appointment.status %>
          </span>

        </div>

        <div class="grid grid-cols-2 gap-4 mt-6 text-sm">

          <div>
            <p class="text-gray-400 font-bold">Department</p>
            <p class="font-black text-gray-800"><%= appointment.department %></p>
          </div>

          <div>
            <p class="text-gray-400 font-bold">Date</p>
            <p class="font-black text-gray-800"><%= appointment.appointmentDate %></p>
          </div>

          <div>
            <p class="text-gray-400 font-bold">Time</p>
            <p class="font-black text-gray-800"><%= appointment.appointmentTime %></p>
          </div>

          <div>
            <p class="text-gray-400 font-bold">Created</p>
            <p class="font-black text-gray-800">
              <%= appointment.createdAt.toDateString() %>
            </p>
          </div>

        </div>

        <div class="mt-7 flex gap-3">

          <a href="/appointments/<%= appointment._id %>" class="btn-luxury">
            View
          </a>

          <a href="/appointments/edit/<%= appointment._id %>" class="bg-blue-500 hover:bg-blue-600 text-white px-5 py-3 rounded-2xl font-black">
            Edit
          </a>

          <form action="/appointments/<%= appointment._id %>?_method=DELETE" method="POST">
            <button class="bg-red-500 hover:bg-red-600 text-white px-5 py-3 rounded-2xl font-black">
              Delete
            </button>
          </form>

        </div>

      </div>

    <% }) %>

  </div>

<% } %>